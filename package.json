  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:dev": "vite build --mode development",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:components": "vitest run tests/components",
    "test:components:all": "ts-node scripts/run-component-tests.ts",
    "test:generate": "ts-node scripts/generate-component-test.ts",
    "api:dev": "dotenv --ignore-missing -e .env.local -- tsx src/server/index.ts",
    "dev:full": "concurrently \"npm run api:dev\" \"npm run dev\"",
    "seed:analytics": "ts-node scripts/seed-analytics-sample.ts",
    "setup:ocr": "bash scripts/setup-ocr.sh",
    "deploy": "./deploy.sh",
    "deploy:push": "git add -A && git commit -m 'Deploy: Auto-commit' && git push origin main",
    "deploy:vercel": "vercel --prod",
    "deploy:vercel:preview": "vercel",
    "deploy:quick": "git add -A && git commit -m 'Deploy: Quick deploy' && git push origin main",
    "apply:schema": "node scripts/db/apply-schema.mjs",
    "dev:web": "vite",
    "dev:auth": "npm --prefix services/auth-api run dev",
    "dev:postgrest": "docker compose -f scripts/postgrest/docker-compose.yml --env-file scripts/postgrest/.env.postgrest up",
    "dev:postgrest:detached": "docker compose -f scripts/postgrest/docker-compose.yml --env-file scripts/postgrest/.env.postgrest up -d",
    "dev:stack": "concurrently -c \"cyan,magenta,green\" -n postgrest,auth,web \"npm run dev:postgrest\" \"npm run dev:auth\" \"npm run dev:web\"",
    "smoke": "node scripts/smoke.mjs"
  },
